      "Bash(npm test *)",
      "Bash(npx playwright *)",
      "Bash(git status *)",
      "Bash(netstat -ano)",
      "Bash(taskkill //PID * //F)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git push *)",
      "Bash(gh pr create *)"
    ]
  }
}
